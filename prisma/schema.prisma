generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String   @map("password_hash")
  role          Role     @default(USER)
  avatarUrl     String?  @map("avatar_url")
  bio           String?
  lastLoginAt   DateTime? @map("last_login_at")
  emailVerified Boolean  @default(false) @map("email_verified")
  website       String?
  socialLinks   Json?    @map("social_links")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // 关系
  posts         Post[]
  media         Media[]
  postLikes     PostLike[]
  analytics     Analytics[]
  notifications Notification[]

  @@map("users")
}

// 标签模型
model Tag {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  color       String?  // 十六进制颜色值
  icon        String?  // 图标类名或emoji
  createdAt   DateTime @default(now()) @map("created_at")

  // 关系
  posts PostTag[]

  @@map("tags")
}

// 文章模型
model Post {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  content         String      @db.Text
  excerpt         String?     @db.Text
  featuredImage   String?     @map("featured_image")
  status          PostStatus  @default(DRAFT)
  authorId        String      @map("author_id")
  viewCount       Int         @default(0) @map("view_count")
  likeCount       Int         @default(0) @map("like_count")
  wordCount       Int         @default(0) @map("word_count")
  readingTime     Int?        @map("reading_time") // 分钟
  metaKeywords    String?     @map("meta_keywords")
  metaDescription String?     @map("meta_description")
  isFeatured      Boolean     @default(false) @map("is_featured")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  publishedAt     DateTime?   @map("published_at")

  // 关系
  author    User       @relation(fields: [authorId], references: [id])
  tags      PostTag[]
  likes     PostLike[]
  analytics Analytics[]

  @@map("posts")
}

// 文章标签关联模型
model PostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")

  // 关系
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}


// 媒体文件模型
model Media {
  id           String    @id @default(cuid())
  filename     String
  type         MediaType
  url          String
  cdnUrl       String?   @map("cdn_url")
  thumbnailUrl String?   @map("thumbnail_url")
  mimeType     String?   @map("mime_type")
  size         Int?
  width        Int?
  height       Int?
  altText      String?   @map("alt_text")
  folder       String?   // 文件夹分类
  uploaderId   String    @map("uploader_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  // 关系
  uploader User @relation(fields: [uploaderId], references: [id])

  @@map("media")
}

// 文章点赞模型
model PostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // 关系
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("post_likes")
}

// 项目展示模型
model Project {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String        @db.Text
  content       String        @db.Text
  coverImage    String?       @map("cover_image")
  demoUrl       String?       @map("demo_url")
  githubUrl     String?       @map("github_url")
  techStack     Json          @map("tech_stack") // ["Next.js", "TypeScript", "Tailwind"]
  status        ProjectStatus @default(DRAFT)
  featured      Boolean       @default(false)
  order         Int           @default(0)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  publishedAt   DateTime?     @map("published_at")

  @@map("projects")
}

// 系统设置模型
model Setting {
  key         String   @id
  value       Json?    // 支持复杂配置
  type        String   @default("json") // json, string, number, boolean
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// 访问统计模型
model Analytics {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  postId     String?  @map("post_id")
  userId     String?  @map("user_id")
  pageUrl    String   @map("page_url")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  referrer   String?
  device     String?  // mobile, tablet, desktop
  browser    String?
  os         String?
  country    String?
  city       String?
  duration   Int?     // 页面停留时间（秒）
  createdAt  DateTime @default(now()) @map("created_at")

  // 关系
  post Post? @relation(fields: [postId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
  @@map("analytics")
}

// 通知模型
model Notification {
  id        String           @id @default(cuid())
  userId    String?          @map("user_id") // null表示发送给所有用户
  type      NotificationType
  title     String
  content   String?          @db.Text
  data      Json?            // 额外数据
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  // 关系
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// 枚举类型
enum Role {
  ADMIN
  USER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  SYSTEM      // 系统通知
  POST_LIKE   // 文章被点赞
  NEW_POST    // 新文章发布
  MAINTENANCE // 维护通知
  LIKE        // 点赞通知（兼容旧代码）
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}
